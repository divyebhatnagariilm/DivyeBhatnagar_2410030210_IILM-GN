# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Stock Market Application Environment Variables
# Copy to .env and fill in your values. Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend ──────────────────────────────────────────────────────────────────

# Port the FastAPI server listens on
API_PORT=8000

# WebSocket publisher settings
WS_PUBLISH_INTERVAL=2        # seconds between price broadcasts per ticker
WS_CACHE_TTL=5               # seconds to cache a yfinance fetch per ticker
WS_SIMULATE_NOISE=0.0003     # max ±% random-walk when market is closed

# Optional: Finnhub API key for enhanced real-time data
# Sign up free at https://finnhub.io
# FINNHUB_API_KEY=your_finnhub_key_here

# Optional: Alpha Vantage API key for intraday candles
# Sign up free at https://www.alphavantage.co
# ALPHAVANTAGE_API_KEY=your_alpha_vantage_key_here

# CORS — comma-separated allowed origins (use * only in development)
CORS_ORIGINS=*

# ── Frontend (Vite) ───────────────────────────────────────────────────────────

# REST API base URL consumed by the frontend
VITE_API_URL=http://localhost:8000

# WebSocket base URL (ws:// for local, wss:// in production)
VITE_WS_URL=ws://localhost:8000
